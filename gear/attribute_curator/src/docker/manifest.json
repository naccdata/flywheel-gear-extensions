{
    "name": "attribute-curator",
    "label": "ADD GEAR LABEL",
    "description": "DESCRIBE GEAR",
    "version": "0.0.1",
    "author": "NACC",
    "maintainer": "NACC <nacchelp@uw.edu>",
    "cite": "",
    "license": "MPL-2.0",
    "url": "https://naccdata.github.io/flywheel-gear-extensions",
    "source": "https://github.com/naccdata/flywheel-gear-extensions",
    "environment": {
        "FLYWHEEL": "/flywheel/v0"
    },
    "custom": {
        "gear-builder": {
            "category": "utility",
            "image": "naccdata/attribute-curator:0.0.1"
        },
        "flywheel": {
            "suite": "Curation",
            "show-job": true
        }
    },
    "inputs": {
        "api-key": {
            "base": "api-key"
        },
        "input_file": {
            "description": "the subject level source file",
            "base": "file",
            "optional": true,
            "type": {
                "enum": [
                    "source code"
                ]
            }
        }
    },
    "config": {
        "dry_run": {
            "description": "Whether to do a dry run. Will run curation but will not apply changes.",
            "type": "boolean",
            "default": false
        },
        "curation_schema_uri": {
            "description": "Curation schema S3 URI",
            "type": "string",
            "default": "nacc-qc-rules-staging/emily-test/mqt-curation.yaml"
        },
        "form_date_key": {
            "description": "Form key to use in order to determine whether a curated field is the latest or not. If not provided, defaults to the form's last modified date.",
            "type": "string",
            "default": ""
        },
        "aggregation_containers": {
            "description": "Comma-deliminated list of parent containers to pull supplement metadata from",
            "type": "string",
            "default": "project.info,session.info,acquistion.info,subject.info"
        },
        "apply_containers": {
            "description": "Comma-deliminated list of containers to apply curated metadata changes to",
            "type": "string",
            "default": "subject"
        },
        "cross_sectional": {
            "description": "Whether or not cross-sectional information is required",
            "type": "boolean",
            "default": true
        },
        "apikey_path_prefix": {
            "description": "The instance specific AWS parameter gearbot path prefix",
            "type": "string",
            "default": "/prod/flywheel/gearbot"
        }
    },
    "command": "/bin/run"
}