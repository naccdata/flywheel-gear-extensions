{
  "name": "gather-form-data",
  "label": "Gather Form Data",
  "description": "Gathers form data across centers",
  "version": "0.1.5",
  "author": "NACC",
  "maintainer": "NACC <nacchelp@uw.edu>",
  "cite": "",
  "license": "MPL-2.0",
  "url": "https://naccdata.github.io/flywheel-gear-extensions/gather_form_data/",
  "source": "https://github.com/naccdata/flywheel-gear-extensions/tree/main/gear/gather_form_data",
  "environment": {
    "FLYWHEEL": "/flywheel/v0"
  },
  "custom": {
    "gear-builder": {
      "category": "utility",
      "image": "naccdata/gather-form-data:0.1.5"
    },
    "flywheel": {
      "suite": "Utility",
      "show-job": true
    }
  },
  "inputs": {
    "api-key": {
      "base": "api-key"
    },
    "input_file": {
      "description": "A participant list CSV file",
      "base": "file",
      "optional": true,
      "type": {
        "enum": [
          "tabular data"
        ]
      }
    }
  },
  "config": {
    "execution_mode": {
      "description": "Execution mode: participant_list or project",
      "type": "string",
      "default": "participant_list",
      "enum": [
        "participant_list",
        "project"
      ]
    },
    "group_id": {
      "description": "Flywheel group ID for the center (required in project mode)",
      "type": "string",
      "optional": true
    },
    "project_name": {
      "description": "Project label to iterate (required in project mode)",
      "type": "string",
      "optional": true
    },
    "dry_run": {
      "description": "Whether to do a dry run",
      "type": "boolean",
      "default": false
    },
    "apikey_path_prefix": {
      "description": "The instance specific AWS parameter path prefix for apikey",
      "type": "string",
      "default": "/prod/flywheel/gearbot"
    },
    "project_names": {
      "description": "Comma-separated list of projects to search",
      "type": "string",
      "default": "ingest-form"
    },
    "include_derived": {
      "description": "Whether to include derived variables",
      "type": "boolean",
      "default": false
    },
    "modules": {
      "description": "Comma-separated list of form modules to include",
      "type": "string",
      "default": "UDS,FTLD,LBD"
    },
    "study_id": {
      "description": "The study ID",
      "type": "string",
      "default": "adrc"
    }
  },
  "command": "/bin/run"
}
