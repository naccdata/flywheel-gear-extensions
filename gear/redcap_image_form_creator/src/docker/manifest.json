{
    "name": "redcap-image-form-creator",
    "label": "REDCap Image Form Creator",
    "description": "Creates REDCap entry and populates form from uploaded images",
    "version": "0.0.3",
    "author": "NACC",
    "maintainer": "NACC <nacchelp@uw.edu>",
    "cite": "",
    "license": "MPL-2.0",
    "url": "https://naccdata.github.io/flywheel-gear-extensions",
    "source": "https://github.com/naccdata/flywheel-gear-extensions",
    "environment": {
        "FLYWHEEL": "/flywheel/v0"
    },
    "custom": {
        "gear-builder": {
            "category": "utility",
            "image": "naccdata/redcap-image-form-creator:0.0.3"
        },
        "flywheel": {
            "suite": "Utility",
            "show-job": true
        }
    },
    "inputs": {
        "api-key": {
            "base": "api-key"
        }
    },
    "config": {
        "dry_run": {
            "description": "Whether to do a dry run",
            "type": "boolean",
            "default": false
        },
        "parameter_path": {
            "description": "AWS parameter path for REDCap instance",
            "type": "string",
            "default": "/redcap/aws/image-submission-edc"
        }
    },
    "command": "/bin/run"
}
