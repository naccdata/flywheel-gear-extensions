{
  "name": "redcap-fw-transfer",
  "label": "REDCap to Flywheel Transfer",
  "description": "Gear to transfer from data from a REDCap project to the respective Flywheel project",
  "version": "1.2.0",
  "author": "NACC",
  "maintainer": "NACC <nacchelp@uw.edu>",
  "cite": "",
  "license": "MPL-2.0",
  "url": "https://naccdata.github.io/flywheel-gear-extensions/redcap_fw_transfer/",
  "source": "https://github.com/naccdata/flywheel-gear-extensions/tree/main/gear/redcap_fw_transfer",
  "environment": {
    "FLYWHEEL": "/flywheel/v0"
  },
  "custom": {
    "gear-builder": {
      "category": "utility",
      "image": "naccdata/redcap-fw-transfer:1.2.0"
    },
    "flywheel": {
      "suite": "Import",
      "show-job": true
    }
  },
  "inputs": {
    "api-key": {
      "base": "api-key"
    }
  },
  "config": {
    "apikey_path_prefix": {
      "description": "The instance specific AWS parameter gearbot path prefix",
      "type": "string",
      "default": "/prod/flywheel/gearbot"
    },
    "parameter_path": {
      "description": "AWS parameter base path for REDCap instance",
      "type": "string",
      "default": "/redcap/aws"
    }
  },
  "command": "/bin/run"
}
