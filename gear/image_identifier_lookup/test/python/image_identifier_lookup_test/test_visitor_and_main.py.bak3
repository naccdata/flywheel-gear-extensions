    ) -> None:
        """Test QC logging on processing failure."""
        # Arrange
        ptid = "110001"
        adcid = 42

        # Mock processor to raise error
        mock_processor = Mock()
        mock_processor.lookup_and_update.side_effect = IdentifierRepositoryError(
            "No matching record"
