        mock_processor.lookup_and_update.return_value = naccid
        mock_processor_class.return_value = mock_processor

        # Mock QC manager
        mock_qc_manager = Mock()
        mock_qc_manager.update_qc_log.return_value = (
            "110001_2024-01-15_mr_qc-status.log"
